<Window x:Class="DFeViewer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:DFeViewer.ViewModels"
        Title="DFe Viewer — Leitor de Documentos Fiscais Eletrônicos"
        Height="750" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontFamily="Segoe UI"
        AllowDrop="True"
        Drop="Window_Drop"
        DragOver="Window_DragOver"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════ TOOLBAR -->
        <md:ColorZone Mode="PrimaryMid" Grid.Row="0" Padding="12,8">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <md:PackIcon Kind="FileDocument" Width="28" Height="28"
                                 Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="DFe Viewer" FontSize="18" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock Text="  |  NF-e · NFC-e · CT-e · MDF-e"
                               FontSize="12" Foreground="#B3E5FC" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <!-- Abrir XML -->
                    <Button Style="{StaticResource MaterialDesignFlatLightButton}"
                            Command="{Binding AbrirXmlCommand}"
                            Margin="4,0" Foreground="White">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="FolderOpen" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Abrir XML" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Imprimir -->
                    <Button Style="{StaticResource MaterialDesignFlatLightButton}"
                            Command="{Binding ImprimirCommand}"
                            Margin="4,0" Foreground="White"
                            IsEnabled="{Binding TemDocumento}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Printer" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Imprimir" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Salvar PDF -->
                    <Button Style="{StaticResource MaterialDesignFlatLightButton}"
                            Command="{Binding ExportarCommand}"
                            Margin="4,0" Foreground="White"
                            IsEnabled="{Binding TemDocumento}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="FilePdfBox" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Salvar PDF" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Copiar Chave -->
                    <Button Style="{StaticResource MaterialDesignFlatLightButton}"
                            Command="{Binding CopiarChaveCommand}"
                            Margin="4,0" Foreground="White"
                            IsEnabled="{Binding TemDocumento}"
                            ToolTip="Copiar chave de acesso">
                        <md:PackIcon Kind="ContentCopy" VerticalAlignment="Center"/>
                    </Button>

                    <!-- Toggle Tema -->
                    <ToggleButton Style="{StaticResource MaterialDesignFlatPrimaryToggleButton}"
                                  IsChecked="{Binding TemaEscuro, Mode=OneWay}"
                                  Command="{Binding AlternarTemaCommand}"
                                  Margin="4,0"
                                  Foreground="White"
                                  ToolTip="Alternar tema claro/escuro">
                        <md:PackIcon Kind="WeatherNight" VerticalAlignment="Center"/>
                    </ToggleButton>

                    <!-- Limpar -->
                    <Button Style="{StaticResource MaterialDesignFlatLightButton}"
                            Command="{Binding LimparTudoCommand}"
                            Margin="4,0" Foreground="#FFCDD2"
                            ToolTip="Remover todos os documentos">
                        <md:PackIcon Kind="DeleteSweep" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </md:ColorZone>

        <!-- ══════════════════════════════════════════ CONTEÚDO PRINCIPAL -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="220"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ─────────────────────── PAINEL ESQUERDO -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{DynamicResource MaterialDesignToolBarBackground}" Padding="12,8">
                    <TextBlock Text="DOCUMENTOS CARREGADOS"
                               FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                </Border>

                <!-- Campo de filtro -->
                <TextBox Grid.Row="1"
                         Text="{Binding FiltroTexto, UpdateSourceTrigger=PropertyChanged}"
                         Margin="8,6,8,2"
                         md:HintAssist.Hint="Filtrar por emitente, número, chave..."
                         md:HintAssist.IsFloating="False"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         FontSize="11">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Escape" Command="{Binding LimparFiltroCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <!-- Lista de documentos -->
                <Grid Grid.Row="2">
                    <Border Visibility="{Binding Documentos.Count, Converter={StaticResource ZeroToVisibleConverter}}"
                            BorderBrush="#BBDEFB" BorderThickness="2" Margin="16"
                            CornerRadius="8" Background="{DynamicResource MaterialDesignCardBackground}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <md:PackIcon Kind="CloudUpload" Width="48" Height="48"
                                         HorizontalAlignment="Center" Foreground="#90CAF9"/>
                            <TextBlock Text="Arraste arquivos XML" TextAlignment="Center"
                                       Foreground="#90CAF9" Margin="0,8,0,4"/>
                            <TextBlock Text="ou clique em 'Abrir XML'" TextAlignment="Center"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}" FontSize="11"/>
                        </StackPanel>
                    </Border>

                    <ListBox ItemsSource="{Binding DocumentosView}"
                             SelectedItem="{Binding DocumentoSelecionado}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="4,2" CornerRadius="4"
                                        Background="{DynamicResource MaterialDesignCardBackground}"
                                        BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1"
                                                          Color="#BDBDBD" Opacity="0.3"/>
                                    </Border.Effect>
                                    <Grid Margin="10,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0" CornerRadius="3" Padding="4,2"
                                                Margin="0,0,8,0" VerticalAlignment="Top">
                                            <Border.Background>
                                                <Binding Path="Tipo" Converter="{StaticResource TipoToColorConverter}"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding TipoLabel}"
                                                       FontSize="9" FontWeight="Bold" Foreground="White"/>
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding EmitenteNome}"
                                                       FontWeight="SemiBold" FontSize="11"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Foreground="{DynamicResource MaterialDesignBodyLight}" FontSize="10">
                                                <Run Text="Nº "/><Run Text="{Binding NumeroDocumento}"/>
                                                <Run Text=" · "/><Run Text="{Binding DataEmissao, StringFormat={}{0:dd/MM/yy}}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding ValorTotal, StringFormat=R$ {0:N2}}"
                                                       FontWeight="Bold" FontSize="11"
                                                       Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                        </StackPanel>

                                        <Button Grid.Column="2"
                                                Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                Command="{Binding DataContext.RemoverCommand,
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Width="24" Height="24" Padding="0"
                                                VerticalAlignment="Top"
                                                Foreground="{DynamicResource MaterialDesignBodyLight}">
                                            <md:PackIcon Kind="Close" Width="14" Height="14"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem"
                                   BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </Grid>

                <!-- Histórico de recentes -->
                <Expander Grid.Row="3" Header="Recentes"
                          Visibility="{Binding Recentes.Count, Converter={StaticResource NonZeroToVisibleConverter}}"
                          Margin="0,4,0,0">
                    <ListBox ItemsSource="{Binding Recentes}"
                             MaxHeight="140"
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Button Style="{StaticResource MaterialDesignFlatButton}"
                                        Command="{Binding DataContext.AbrirRecenteCommand,
                                            RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        HorizontalContentAlignment="Left"
                                        Padding="4,2" FontSize="10"
                                        ToolTip="{Binding}">
                                    <TextBlock Text="{Binding Path=., Converter={StaticResource NomeArquivoConverter}}"
                                               TextTrimming="CharacterEllipsis" MaxWidth="240"/>
                                </Button>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Expander>
            </Grid>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource MaterialDesignDivider}"/>

            <!-- ─────────────────────── PAINEL DIREITO: Detalhes -->
            <Grid Grid.Column="2">

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding TemDocumento, Converter={StaticResource BoolToInvisibleConverter}}">
                    <md:PackIcon Kind="FileDocumentOutline" Width="72" Height="72"
                                 HorizontalAlignment="Center" Foreground="{DynamicResource MaterialDesignBodyLight}"/>
                    <TextBlock Text="Nenhum documento selecionado"
                               FontSize="16" Foreground="{DynamicResource MaterialDesignBodyLight}"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    <TextBlock Text="Abra um arquivo XML ou arraste-o para a janela"
                               FontSize="13" Foreground="{DynamicResource MaterialDesignBodyLight}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <ProgressBar IsIndeterminate="True" Height="4" VerticalAlignment="Top"
                             Visibility="{Binding Carregando, Converter={StaticResource BoolToVisibleConverter}}"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              Visibility="{Binding TemDocumento, Converter={StaticResource BoolToVisibleConverter}}">
                    <StackPanel Margin="16" DataContext="{Binding DocumentoSelecionado}">

                        <!-- Cabeçalho -->
                        <md:Card Margin="0,0,0,12" Padding="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="16">
                                    <StackPanel Orientation="Horizontal">
                                        <Border CornerRadius="4" Padding="8,4" Margin="0,0,10,0">
                                            <Border.Background>
                                                <Binding Path="Tipo" Converter="{StaticResource TipoToColorConverter}"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding TipoLabel}"
                                                       Foreground="White" FontWeight="Bold" FontSize="13"/>
                                        </Border>
                                        <TextBlock VerticalAlignment="Center" FontSize="20" FontWeight="Bold">
                                            <Run Text="Nº "/><Run Text="{Binding NumeroDocumento}"/>
                                            <Run Text=" — Série "/><Run Text="{Binding Serie}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <TextBlock Margin="0,4,0,0" FontSize="13">
                                        <Run Text="{Binding EmitenteNome}" FontWeight="SemiBold"/>
                                        <Run Text="  ·  "/>
                                        <Run Text="{Binding EmitenteCnpj}"/>
                                    </TextBlock>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Foreground="{DynamicResource MaterialDesignBodyLight}" FontSize="11">
                                            <Run Text="Emissão: "/>
                                            <Run Text="{Binding DataEmissao, StringFormat={}{0:dd/MM/yyyy HH:mm}}"/>
                                            <Run Text="  |  Chave: "/>
                                            <Run Text="{Binding ChaveAcesso}" FontFamily="Consolas" FontSize="10"/>
                                        </TextBlock>
                                        <Button Style="{StaticResource MaterialDesignIconForegroundButton}"
                                                Command="{Binding DataContext.CopiarChaveCommand,
                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                Width="20" Height="20" Padding="0" Margin="6,0,0,0"
                                                ToolTip="Copiar chave de acesso">
                                            <md:PackIcon Kind="ContentCopy" Width="13" Height="13"/>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Column="1" Background="{DynamicResource MaterialDesignToolBarBackground}"
                                        Padding="20,10" Margin="0">
                                    <StackPanel>
                                        <TextBlock Text="VALOR TOTAL" FontSize="9"
                                                   FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding ValorTotal, StringFormat=R$ {0:N2}}"
                                                   FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                        <Border CornerRadius="3" Padding="6,2"
                                                HorizontalAlignment="Center" Margin="0,6,0,0">
                                            <Border.Background>
                                                <Binding Path="Situacao" Converter="{StaticResource SituacaoToColorConverter}"/>
                                            </Border.Background>
                                            <TextBlock Text="{Binding Situacao}"
                                                       Foreground="White" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </md:Card>

                        <!-- Emitente / Destinatário -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <md:Card Grid.Column="0" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="EMITENTE" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding EmitenteNome}" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Foreground="{DynamicResource MaterialDesignBodyLight}">
                                        <Run Text="CNPJ/CPF: "/><Run Text="{Binding EmitenteCnpj}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding DadosExtras[Emitente - Endereço]}"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               TextWrapping="Wrap" FontSize="11"/>
                                </StackPanel>
                            </md:Card>

                            <md:Card Grid.Column="2" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="DESTINATÁRIO / TOMADOR" FontSize="10" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding DestinatarioNome}" FontWeight="SemiBold" FontSize="13"/>
                                    <TextBlock Foreground="{DynamicResource MaterialDesignBodyLight}">
                                        <Run Text="CNPJ/CPF: "/><Run Text="{Binding DestinatarioCnpjCpf}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding DadosExtras[Destinatário - Endereço]}"
                                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                                               TextWrapping="Wrap" FontSize="11"/>
                                </StackPanel>
                            </md:Card>
                        </Grid>

                        <!-- Dados extras -->
                        <md:Card Margin="0,0,0,12" Padding="16">
                            <StackPanel>
                                <TextBlock Text="DADOS DO DOCUMENTO" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,10"/>
                                <ItemsControl ItemsSource="{Binding DadosExtras}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="4" Padding="10,6"
                                                    Background="{DynamicResource MaterialDesignToolBarBackground}"
                                                    CornerRadius="4" MinWidth="150">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Key}"
                                                               FontSize="9" Foreground="{DynamicResource MaterialDesignBodyLight}"
                                                               FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding Value}"
                                                               FontSize="12" TextWrapping="Wrap" MaxWidth="250"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </md:Card>

                        <!-- Itens NF-e -->
                        <md:Card Margin="0,0,0,12" Padding="16"
                                 Visibility="{Binding Itens.Count, Converter={StaticResource NonZeroToVisibleConverter}}">
                            <StackPanel>
                                <TextBlock Text="PRODUTOS / SERVIÇOS" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,10"/>
                                <DataGrid ItemsSource="{Binding Itens}"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          GridLinesVisibility="Horizontal"
                                          HeadersVisibility="Column"
                                          CanUserReorderColumns="False"
                                          CanUserResizeRows="False"
                                          BorderThickness="0"
                                          Background="Transparent"
                                          AlternatingRowBackground="{DynamicResource MaterialDesignToolBarBackground}"
                                          FontSize="11">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Nº"       Binding="{Binding Numero}"         Width="40"/>
                                        <DataGridTextColumn Header="Código"   Binding="{Binding Codigo}"         Width="80"/>
                                        <DataGridTextColumn Header="Descrição" Binding="{Binding Descricao}"     Width="*"/>
                                        <DataGridTextColumn Header="NCM"      Binding="{Binding Ncm}"            Width="80"/>
                                        <DataGridTextColumn Header="CFOP"     Binding="{Binding Cfop}"           Width="60"/>
                                        <DataGridTextColumn Header="UN"       Binding="{Binding Unidade}"        Width="50"/>
                                        <DataGridTextColumn Header="Qtd"      Binding="{Binding Quantidade, StringFormat={}{0:N3}}"        Width="80"/>
                                        <DataGridTextColumn Header="V. Unit."  Binding="{Binding ValorUnitario, StringFormat=R$ {0:N2}}"   Width="90"/>
                                        <DataGridTextColumn Header="V. Total"  Binding="{Binding ValorTotal,    StringFormat=R$ {0:N2}}"   Width="90"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Background="{DynamicResource MaterialDesignToolBarBackground}"
                                        Margin="0,8,0,0" Padding="12,8">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <TextBlock Text="Total dos Produtos: " FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                        <TextBlock Text="{Binding Itens, Converter={StaticResource SomaTotalConverter}, StringFormat=R$ {0:N2}}"
                                                   FontWeight="Bold" Foreground="{DynamicResource PrimaryHueMidBrush}" FontSize="14"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </md:Card>

                        <!-- Informações adicionais -->
                        <md:Card Margin="0,0,0,12" Padding="16">
                            <StackPanel>
                                <TextBlock Text="INFORMAÇÕES ADICIONAIS" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding DadosExtras[Informações Adicionais]}"
                                           TextWrapping="Wrap" FontSize="11"/>
                            </StackPanel>
                        </md:Card>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════════ STATUS BAR -->
        <Border Grid.Row="2" Background="{DynamicResource PrimaryHueDarkBrush}" Padding="12,6">
            <TextBlock Text="{Binding StatusMsg}" Foreground="White" FontSize="11"/>
        </Border>
    </Grid>
</Window>
